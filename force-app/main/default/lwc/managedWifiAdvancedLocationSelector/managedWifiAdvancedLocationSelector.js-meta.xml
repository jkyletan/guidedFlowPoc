<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>

    <targets>
        <target>lightning__FlowScreen</target>
    </targets>

    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">

			<propertyType name="T" extends="SObject" label="Record Type"/>

            <!-- Input collection -->
            <property 
				name="locations"
				type="{T[]}"
				role="inputOnly"
				label="Locations" />

            <property 
                name="initialSelectedLocationJSON"
                type="String"
                role="inputOnly"
                label="Initial Selected Location JSON" />

            <!-- Output JSON -->
            <property 
                name="selectedLocationJSON"
                type="String"
                role="outputOnly"
                label="Selected Location JSON" />

        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>